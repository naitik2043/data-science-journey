# The `np.array()` function is used to create NumPy arrays from Python lists or tuples.
arr = np.array([1, 3, 4])


arr


# the `np.zeros()` function creates an array filled with zeros.
np.zeros((3, 4))


# The `np.ones()` function creates an array where every element is 1.
np.ones((3, 5))


# The `np.full()` function creates an array filled with a specified value.
np.full((4, 6), 8)


# The `np.eye()` function creates an identity matrix with ones on the main diagonal and zeros elsewhere.
np.eye(3)


# The `np.arange()` function generates evenly spaced values within a specified range.
np.arange(1, 100, 10)


# The `np.linspace()` function generates a specified number of evenly spaced values between two endpoints.
np.linspace(1, 100, 5)


